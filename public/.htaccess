# Squirrelll.ing — Apache config for cPanel shared hosting
# Serves prerendered per-route index.html to crawlers and users, with SPA fallback.

Options -MultiViews +FollowSymLinks
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Canonical host: squirrelll.ing (strip www)
  RewriteCond %{HTTP_HOST} ^www\.squirrelll\.ing$ [NC]
  RewriteRule ^ https://squirrelll.ing%{REQUEST_URI} [L,R=301]

  # If the request is for an existing file, serve it as-is.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # If a prerendered directory exists for this route (e.g. /what-is-squirrelling/index.html), serve it.
  RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.html -f
  RewriteRule ^(.*?)/?$ /$1/index.html [L]

  # Otherwise fall back to the root index.html so React Router can handle it.
  RewriteRule ^ /index.html [L]
</IfModule>

# Long-cache hashed assets, short-cache HTML so prerender updates propagate.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|xml|txt|json)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml text/javascript application/javascript application/json application/xml application/xml+rss image/svg+xml
</IfModule>

ErrorDocument 404 /index.html
